# Core app
APP_BASE_URL=http://localhost:3000
KEYPOINT_APP_BASE_URL=http://localhost:3000
PORTAL_INVITE_SECRET=change-me
# Legacy shared office code (no longer used for /office — staff uses email/password + Airtable Staff table).
OFFICE_ACCESS_CODE=
OFFICE_SESSION_SECRET=
OFFICE_SESSION_HOURS=12
# Staff browser session signing (HMAC). Strong random value recommended in production.
STAFF_SESSION_SECRET=
# Optional: when set, the login page shows staff self-registration guarded by this secret (header + form field).
STAFF_REGISTER_SECRET=

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_CASES_TABLE=Cases
AIRTABLE_CLIENTS_TABLE=Clients
AIRTABLE_DOCUMENTS_TABLE=Case documents
AIRTABLE_ACTIVITY_LOG_TABLE=Activity log
AIRTABLE_BANK_RUNS_TABLE=Bank runs
AIRTABLE_AI_REVIEWS_TABLE=AI reviews
AIRTABLE_STAFF_TABLE=Staff
AIRTABLE_FINANCE_TRANSACTIONS_TABLE=Finance transactions
AIRTABLE_BILLING_EVENTS_TABLE=Billing events

# Uploads
UPLOAD_DIR=./data/uploads
UPLOAD_PUBLIC_BASE_URL=
# Max upload size in bytes (default 15 MiB if unset)
UPLOAD_MAX_FILE_BYTES=15728640

# Automation / notifications
N8N_WEBHOOK_BASE_URL=
# Optional locally; in production (live URL) required for POST /api/webhooks/n8n unless callers use an office session cookie.
# Send the same value in header: x-keypoint-forwarder-secret
N8N_FORWARDER_SECRET=
OFFICE_ALERT_WEBHOOK_URL=
WHATSAPP_PROVIDER_WEBHOOK_URL=
SMS_PROVIDER_WEBHOOK_URL=
EMAIL_PROVIDER_WEBHOOK_URL=
DOCUMENT_OCR_WEBHOOK_URL=
AI_REVIEW_WEBHOOK_URL=

# Optional providers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=
EMAIL_API_KEY=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=
