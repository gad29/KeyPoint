              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {},
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "filterByFormula",
              "value": "=IF({Region} = \"{{$json.body?.region || $json.region || \"\"}}\", TRUE(), FALSE())"
