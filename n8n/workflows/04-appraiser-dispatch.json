              "name": "maxRecords",
              "value": "10"
            }
          ]
        }
      },
      "id": "cac3352d-cf18-429c-8152-355809a39273",
      "name": "Load Appraisers by Region",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        560,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst input = $('Appraiser Dispatch Webhook').first().json.body ?? $('Appraiser Dispatch Webhook').first().json;\nconst appraisers = $json.records || [];\nif (!appraisers.length) throw new Error('No matching appraiser found');\nconst selected = appraisers[0];\nconst now = new Date().toISOString();\nreturn [{ json: {\n  ...input,\n  now,\n  selectedAppraiser: selected,\n  appraisalJobCreate: {\n    records: [{\n      fields: {\n        'Case link': [input.caseId],\n        'Appraiser link': [selected.id],\n        'Referral sent at': now,\n        'Exceptions / notes': input.notes || '',\n      }\n    }]\n  },\n  activityLogCreate: {\n    records: [{\n      fields: {\n        'Case link': [input.caseId],\n        'Actor': 'n8n',\n        'Event type': 'appraiser_dispatched',\n        'Summary': `Appraiser dispatch sent to ${selected.fields?.Name || 'selected appraiser'}`,\n        'Source system': 'n8n',\n        'Timestamp': now,\n      }\n    }]\n  },\n  appraiserMessage: {\n    appraiserName: selected.fields?.Name,\n    whatsapp: selected.fields?.['WhatsApp number'],\n    email: selected.fields?.Email,\n    caseId: input.caseId,\n    propertyAddress: input.propertyAddress,\n    requestedVisitWindow: input.requestedVisitWindow,\n    valuationContext: input.valuationContext || '',\n  }\n}}];\n"
      },
      "id": "372da770-e0f3-4330-9470-3aeb1f975064",
      "name": "Select Appraiser + Build Job",
