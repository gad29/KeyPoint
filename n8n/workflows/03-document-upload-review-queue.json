        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { caseId: $json.caseId, documentCode: $json.documentCode, fileUrl: $json.fileUrl, languageHint: $json.languageHint || \"he\" } }}"
      },
      "id": "deb2111c-ac11-4420-9b6c-8cb335f44e96",
      "name": "Optional OCR Handoff",
